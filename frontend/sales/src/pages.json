      {
        "pagePath": "pages/marketing/index",
        "text": "营销",
        "iconPath": "static/tabbar/marketing.png",
        "selectedIconPath": "static/tabbar/marketing-active.png"
      },
      {
        "pagePath": "pages/performance/index",
        "text": "业绩",
        "iconPath": "static/tabbar/performance.png",
        "selectedIconPath": "static/tabbar/performance-active.png"
      },
      {
        "pagePath": "pages/mine/index",
